# Access Gate Service (B3 - Product B)
PORT=3003
HOST=0.0.0.0
ENV=development
LOG_LEVEL=info

# Database (SQLite local / PostgreSQL Docker)
DATABASE_URL=sqlite:///./data/access_gate.db
# DATABASE_URL=postgresql://access:access@db:5432/access_gate

# === HỢP ĐỒNG TÍCH HỢP — thống nhất với nhóm B6 và B5 ===
# Core Business (B6) — B3 GỬI access event sang đây
CORE_BUSINESS_URL=http://localhost:3006
CORE_BUSINESS_EVENT_PATH=/api/v1/events/access

# Analytics (B5) — B3 GỬI metric sang đây
ANALYTICS_URL=http://localhost:3005
ANALYTICS_INGEST_PATH=/api/v1/ingest/access

# Timeout khi gọi service khác (giây)
INTEGRATION_TIMEOUT_SECONDS=3

# Tên service (dùng trong payload gửi đi)
SERVICE_NAME=access-gate-b3
SERVICE_PRODUCT=product-b

# === HỢP ĐỒNG B6 NÂNG CAO ===
DEBOUNCE_TTL_SECONDS=2.0
OFFLINE_MODE=fail_closed
BULK_SYNC_BATCH_SIZE=100
BULK_SYNC_MAX_RPS=5
RATE_LIMIT_GLOBAL_RPS=200
RATE_LIMIT_LOG_RPS=50
PASSAGE_TIMEOUT_SECONDS=5

# === CẤU HÌNH MQTT HIVEMQ ===
MQTT_HOST=f6f78e87db4a4c189dd3d706745a5e93.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=DVKN2026
MQTT_PASSWORD=ThaiBao12A@
MQTT_TOPIC_INPUT=smart-campus/raw/access/rfid-uid
MQTT_TOPIC_OUTPUT=smart-campus/events/access
